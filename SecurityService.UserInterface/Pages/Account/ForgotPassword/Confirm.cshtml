@page
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IdentityServerHost.Pages.ForgotPassword.Confirm

<div class="max-w-md mx-auto">

<div class="mb-6 text-center">
    <h1 class="text-2xl font-bold text-gray-900">Reset Password</h1>
</div>

<partial name="_ValidationSummary"/>

<div class="card">
    <div class="card-header">
        <h2 class="card-title">Reset Password</h2>
    </div>

    <div class="card-body">
        <form asp-page="/Account/ForgotPassword/Confirm">
            <input type="hidden" asp-for="@Model.Input.Token"/>
            <input type="hidden" asp-for="@Model.Input.Username"/>
            <input type="hidden" asp-for="@Model.Input.ClientId"/>
            <div class="form-group">
                <label class="form-label" asp-for="@Model.View.Username">@Model.View.Username</label>
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Input.Password"></label>
                <input type="password" class="form-control" placeholder="New Password" asp-for="Input.Password" autocomplete="off">
            </div>

            <div class="form-group">
                <label class="form-label" asp-for="Input.ConfirmPassword"></label>
                <input type="password" class="form-control" placeholder="Confirm New Password" asp-for="Input.ConfirmPassword" autocomplete="off">
            </div>

            <div class="flex gap-2 mt-4">
                <button class="btn btn-primary" name="Input.Button" value="login">Confirm Reset Password</button>
                <button class="btn btn-secondary" name="Input.Button" value="cancel">Cancel</button>
            </div>
        </form>
    </div>
</div>

</div>