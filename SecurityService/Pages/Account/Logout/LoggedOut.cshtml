@page
@model SecurityService.Pages.Account.Logout.LoggedOutModel
@{
    ViewData["Title"] = "Logged out";
}

<div class="centered-card">
    <div class="card">
        <div class="card__body">
            <div class="hero">
                <h1 class="hero__title">Logged out</h1>
                <p class="hero__subtitle">You have been signed out successfully.</p>
            </div>

            <div class="actions">
                <a class="btn btn-primary" href="/Account/Login">Return to login</a>
            </div>
        </div>
    </div>
</div>
