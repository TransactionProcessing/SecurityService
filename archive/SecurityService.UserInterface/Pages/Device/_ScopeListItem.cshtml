@using IdentityServerHost.Pages.Device
@model ScopeViewModel

<li class="px-4 py-3 bg-white">
    <label class="flex items-start gap-2 cursor-pointer">
        <input class="mt-0.5 h-4 w-4 rounded border-gray-300 consent-scopecheck"
               type="checkbox"
               name="Input.ScopesConsented"
               id="scopes_@Model.Value"
               value="@Model.Value"
               checked="@Model.Checked"
               disabled="@Model.Required" />
        @if (Model.Required)
        {
            <input type="hidden"
                   name="Input.ScopesConsented"
                   value="@Model.Value" />
        }
        <span class="text-sm text-gray-900">
            <strong>@Model.DisplayName</strong>
            @if (Model.Emphasize)
            {
                <svg class="inline w-4 h-4 ml-1 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
                </svg>
            }
        </span>
    </label>
    @if (Model.Required)
    {
        <span class="text-xs text-gray-500 ml-6"><em>(required)</em></span>
    }
    @if (Model.Description != null)
    {
        <div class="mt-1 ml-6 consent-description">
            <label class="text-xs text-gray-500" for="scopes_@Model.Value">@Model.Description</label>
        </div>
    }
</li>