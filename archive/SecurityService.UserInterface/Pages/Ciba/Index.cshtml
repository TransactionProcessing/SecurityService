@page
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IdentityServerHost.Pages.Ciba.IndexModel
@{
}

<div class="mb-6">
    @if (Model.LoginRequest.Client.LogoUri != null)
    {
        <img src="@Model.LoginRequest.Client.LogoUri" class="h-12 mb-3">
    }
    <h1 class="text-2xl font-bold text-gray-900">
        @Model.LoginRequest.Client.ClientName
        <span class="text-base font-normal text-gray-500 ml-2">is requesting your permission</span>
    </h1>
</div>

<div class="card max-w-lg">
    <div class="card-body space-y-4">
        <p class="text-gray-700">
            Verify that this identifier matches what the client is displaying:
            <em class="text-admin-primary font-medium">@Model.LoginRequest.BindingMessage</em>
        </p>
        <p class="text-gray-700">Do you wish to continue?</p>
        <div>
            <a class="btn btn-primary" asp-page="/Ciba/Consent" asp-route-id="@Model.LoginRequest.InternalId">Yes, Continue</a>
        </div>
    </div>
</div>
