@page
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model IdentityServerHost.Pages.EmailConfirmation.Confirm

<div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Email Confirmation</h1>
</div>

<partial name="_ValidationSummary"/>

<div class="max-w-lg">
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">Confirm Email Address</h2>
        </div>

        <div class="card-body">
            <p id="userMessage" class="text-gray-700">@Model.View.UserMessage</p>
        </div>
    </div>
</div>